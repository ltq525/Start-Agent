# LLM provider settings
LLM_MODEL_ID="gpt-3.5-turbo"
LLM_API_KEY="your-llm-api-key"
LLM_BASE_URL="https://api.openai.com/v1"
LLM_PROVIDER="custom"
LLM_TIMEOUT="60"

# Search providers
SERPAPI_API_KEY="your-serpapi-api-key"
TAVILY_API_KEY="your-tavily-api-key"
PERPLEXITY_API_KEY="your-perplexity-api-key"

# Optional Google Search locale settings
GOOGLE_SEARCH_HL="zh-cn"
GOOGLE_SEARCH_GL="cn"

# Qdrant vector database settings
# Cloud example:
QDRANT_URL="https://your-cluster-url.qdrant.io:6333"
QDRANT_API_KEY="your-qdrant-api-key"

# Local example:
# QDRANT_URL="http://localhost:6333"
# QDRANT_API_KEY=""

QDRANT_COLLECTION="start_agent_vectors"
QDRANT_VECTOR_SIZE="1024"
QDRANT_DISTANCE="cosine"
QDRANT_TIMEOUT="30"

# Neo4j graph database settings
# Cloud example:
NEO4J_URI="neo4j+s://your-instance.databases.neo4j.io"
NEO4J_USERNAME="neo4j"
NEO4J_PASSWORD="your-neo4j-password"
NEO4J_DATABASE="neo4j"
AURA_INSTANCEID="your-aura-instance-id"
AURA_INSTANCENAME="your-aura-instance-name"

# Local example:
# NEO4J_URI="bolt://localhost:7687"
# NEO4J_USERNAME="neo4j"
# NEO4J_PASSWORD="your-local-neo4j-password"

NEO4J_MAX_CONNECTION_LIFETIME="3600"
NEO4J_MAX_CONNECTION_POOL_SIZE="50"
NEO4J_CONNECTION_TIMEOUT="60"

# Embedding settings
EMBED_MODEL_TYPE="dashscope"
EMBED_MODEL_NAME="text-embedding-v3"
EMBED_API_KEY="your-embedding-api-key"
EMBED_BASE_URL="https://dashscope.aliyuncs.com/compatible-mode/v1"
EMBED_DIMENSION="1024"
EMBED_RES_LEVEL="1"

# GitHub API settings
GITHUB_PERSONAL_ACCESS_TOKEN="your-github-personal-access-token"
